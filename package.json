{
  "name": "shelfie",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "NODE_ENV=production node index.js",
    "dev": "NODE_ENV=development node --watch index.js",
    "test": "NODE_ENV=test node --test",
    "migrate:up": "node-pg-migrate up -d DEV_DATABASE_URI",
    "migrate:down": "node-pg-migrate down -d DEV_DATABASE_URI",
    "migrate:create": "node-pg-migrate create",
    "migrate:up:test": "node-pg-migrate up -d TEST_DATABASE_URI",
    "migrate:down:test": "node-pg-migrate down -d TEST_DATABASE_URI",
    "lint": "eslint ."
  },
  "node-pg-migrate": {
    "decamelize": true,
    "timestamp": false
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "supertest": "^7.2.2"
  }
}
